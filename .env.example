# Database
DATABASE_URL=mysql://root:password@localhost:3306/agentpress_dev

# Server
PORT=3001
SESSION_SECRET=change-me-in-production
CORS_ORIGIN=http://localhost:5173
# Account schedule worker (set false for API-only processes)
SCHEDULES_ENABLED=true
SCHEDULE_POLL_MS=30000
SCHEDULE_MISSED_GRACE_MS=90000

# Web
VITE_API_URL=http://localhost:3001

# OpenAI
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=gpt-image-1
# OPENAI_IMAGE_SIZE=1024x1024
# Legacy dall-e-2/dall-e-3 are unavailable on many accounts; use gpt-image-1 instead.

# Storage
OUTPUT_ROOT=./outputs
APP_BASE_URL=http://localhost:3001
# WSL + WAMP: server-side fetch to WordPress on localhost needs the Windows host IP.
# WINDOWS_HOST_IP=172.19.112.1

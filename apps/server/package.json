{
  "name": "server",
  "version": "0.0.1",
  "scripts": {
    "dev": "cross-env CHOKIDAR_USEPOLLING=1 CHOKIDAR_INTERVAL=250 tsx watch --env-file=../../.env src/index.ts",
    "build": "tsc",
    "start": "tsx src/index.ts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "test:static": "tsc --noEmit",
    "lint": "pnpm run test:static"
  },
  "dependencies": {
    "@fastify/cookie": "^9.0.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/static": "^7.0.4",
    "@fastify/swagger": "^8.0.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@project/content": "workspace:*",
    "@project/db": "workspace:*",
    "bcryptjs": "^2.4.3",
    "fastify": "^4.0.0",
    "fastify-openapi-glue": "^4.0.0",
    "js-yaml": "^4.0.0",
    "openai": "^4.0.0",
    "rss-parser": "^3.13.0",
    "sharp": "^0.35.1",
    "youtube-transcript": "^1.3.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.0",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^20.0.0",
    "cross-env": "^7.0.3",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}

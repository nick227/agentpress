generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                      @id @default(cuid())
  email                  String                      @unique
  passwordHash           String
  role                   String                      @default("OWNER")
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  sessions               Session[]
  workspaceMemberships   WorkspaceMember[]
  createdPipelines       Pipeline[]                  @relation("PipelineCreator")
  createdResearchSources ResearchSource[]            @relation("ResearchSourceCreator")
  createdDestinations    Destination[]               @relation("DestinationCreator")
  createdPipelineRuns    PipelineRun[]               @relation("PipelineRunCreator")
  createdSchedules       Schedule[]                  @relation("ScheduleCreator")
  createdAgents          Agent[]                     @relation("AgentCreator")
  feedSubscriptions      WorkspaceFeedSubscription[] @relation("FeedSubscriptionCreator")
  auditEvents            AuditEvent[]                @relation("AuditActor")
}

enum WorkspaceType {
  PERSONAL
  TEAM
  COMMUNITY
}

enum WorkspaceRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum Visibility {
  PRIVATE
  PUBLIC
}

enum PromptKind {
  TRANSFORMATIONAL
  CONTENT
}

enum AgentKind {
  AI_TEXT
  AI_IMAGE
  STATIC_TEXT
  STATIC_IMAGE
}

model Workspace {
  id                String                      @id @default(cuid())
  type              WorkspaceType
  name              String
  slug              String                      @unique
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  members           WorkspaceMember[]
  pipelines         Pipeline[]
  researchSources   ResearchSource[]
  destinations      Destination[]
  pipelineRuns      PipelineRun[]
  schedules         Schedule[]
  feedSubscriptions WorkspaceFeedSubscription[]
  prompts           Prompt[]
  agents            Agent[]
  workflows         Workflow[]
  auditEvents       AuditEvent[]
}

model AuditEvent {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actorUserId String?
  actor       User?     @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  action      String
  targetType  String
  targetId    String
  metadata    Json?
  createdAt   DateTime  @default(now())

  @@index([workspaceId, createdAt])
  @@index([targetType, targetId])
}

model WorkspaceMember {
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        WorkspaceRole
  joinedAt    DateTime      @default(now())

  @@id([workspaceId, userId])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Pipeline {
  id               String                   @id @default(cuid())
  name             String
  slug             String
  description      String?                  @db.Text
  category         String?
  status           String                   @default("draft")
  destinationId    String?
  wpCategoryIds    Json?
  bodyComposer     Json?
  dryRun           Boolean                  @default(true)
  scheduleMode     String                   @default("manual")
  frequency        String?
  timeOfDay        String?
  timezone         String?
  isPaused         Boolean                  @default(false)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  workspaceId      String
  workspace        Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  visibility       Visibility               @default(PRIVATE)
  createdByUserId  String?
  createdBy        User?                    @relation("PipelineCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  sourcePipelineId String?
  sourcePipeline   Pipeline?                @relation("PipelineForks", fields: [sourcePipelineId], references: [id], onDelete: SetNull)
  forks            Pipeline[]               @relation("PipelineForks")
  sourceVersionAt  DateTime?
  forkedAt         DateTime?
  variables        PipelineVariable[]
  agents           PipelineAgent[]
  runs             PipelineRun[]
  imageAssets      ImageAsset[]
  scheduleActions  SchedulePipelineAction[]
  feedLinks        PipelineFeed[]
  loop             PipelineLoop?
  batches          PipelineRunBatch[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, visibility, updatedAt])
}

model PipelineVariable {
  id           String   @id @default(cuid())
  pipelineId   String
  pipeline     Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  key          String
  label        String?
  type         String   @default("text")
  required     Boolean  @default(false)
  defaultValue String?
  exampleValue String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PipelineAgent {
  id                   String        @id @default(cuid())
  pipelineId           String
  pipeline             Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  uid                  String
  kind                 AgentKind     @default(AI_TEXT)
  sourceAgentId        String?
  sourceAgent          Agent?        @relation(fields: [sourceAgentId], references: [id], onDelete: SetNull)
  sourceWorkflowNodeId String?
  sourceWorkflowNode   WorkflowNode? @relation("PipelineAgentWorkflowNode", fields: [sourceWorkflowNodeId], references: [id], onDelete: SetNull)
  name                 String
  systemPrompt         String        @db.Text
  userPrompt           String        @db.Text
  outputTarget         String
  outputFormat         String        @default("text")
  imageMode            String        @default("generate")
  selectedImageAssetId String?
  selectedImageAsset   ImageAsset?   @relation("SelectedImageAsset", fields: [selectedImageAssetId], references: [id], onDelete: SetNull)
  enabled              Boolean       @default(true)
  sortOrder            Int           @default(0)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  imageAssets          ImageAsset[]  @relation("AgentImageAssets")
  agentRuns            AgentRun[]    @relation("PipelineAgentRuns")

  @@unique([pipelineId, uid])
  @@index([sourceAgentId])
  @@index([sourceWorkflowNodeId])
}

model ImageAsset {
  id               String          @id @default(cuid())
  pipelineId       String?
  pipeline         Pipeline?       @relation(fields: [pipelineId], references: [id], onDelete: SetNull)
  agentId          String?
  agentUid         String?
  agent            PipelineAgent?  @relation("AgentImageAssets", fields: [agentId], references: [id], onDelete: SetNull)
  prompt           String          @db.Text
  provider         String
  model            String
  size             String?
  path             String
  url              String?
  status           String          @default("ready")
  error            String?         @db.Text
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  selectedByAgents PipelineAgent[] @relation("SelectedImageAsset")
}

model PipelineRun {
  id                          String                     @id @default(cuid())
  pipelineId                  String?
  pipeline                    Pipeline?                  @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  workflowId                  String?
  workflow                    Workflow?                  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  title                       String?
  status                      String                     @default("queued")
  dryRun                      Boolean                    @default(true)
  variables                   Json
  generatedPost               Json?
  outputFolder                String?
  destinationId               String?
  startedAt                   DateTime                   @default(now())
  completedAt                 DateTime?
  error                       String?                    @db.Text
  workspaceId                 String
  workspace                   Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdByUserId             String?
  createdBy                   User?                      @relation("PipelineRunCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  agentRuns                   AgentRun[]
  assets                      RunAsset[]
  publishAttempts             PublishAttempt[]
  schedulePipelineExecutionId String?                    @unique
  schedulePipelineExecution   SchedulePipelineExecution? @relation(fields: [schedulePipelineExecutionId], references: [id], onDelete: SetNull)
  batchId                     String?
  batch                       PipelineRunBatch?          @relation(fields: [batchId], references: [id], onDelete: SetNull)
  loopIndex                   Int?

  @@index([workspaceId, startedAt])
  @@index([batchId])
  @@index([workflowId])
}

model AgentRun {
  id                   String         @id @default(cuid())
  pipelineRunId        String
  pipelineRun          PipelineRun    @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)
  pipelineAgentId      String?
  pipelineAgent        PipelineAgent? @relation("PipelineAgentRuns", fields: [pipelineAgentId], references: [id], onDelete: SetNull)
  workflowNodeId       String?
  workflowNode         WorkflowNode?  @relation("WorkflowNodeRuns", fields: [workflowNodeId], references: [id], onDelete: SetNull)
  agentUid             String
  agentName            String
  agentKind            AgentKind      @default(AI_TEXT)
  outputFormat         String         @default("text")
  outputTarget         String
  renderedSystemPrompt String         @db.Text
  renderedUserPrompt   String         @db.Text
  inputHash            String?
  cacheStatus          String?
  reusedFromAgentRunId String?
  outputText           String?        @db.Text
  outputJson           Json?
  status               String         @default("queued")
  error                String?
  sortOrder            Int            @default(0)
  startedAt            DateTime?
  completedAt          DateTime?

  @@index([agentUid, inputHash])
  @@index([pipelineAgentId])
  @@index([workflowNodeId])
}

model RunAsset {
  id            String      @id @default(cuid())
  pipelineRunId String
  pipelineRun   PipelineRun @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)
  type          String
  label         String
  filename      String
  path          String
  url           String?
  createdAt     DateTime    @default(now())
}

model Destination {
  id                 String           @id @default(cuid())
  type               String           @default("wordpress")
  name               String
  siteUrl            String
  authType           String           @default("application_password")
  username           String?
  encryptedSecret    String
  defaultStatus      String           @default("draft")
  defaultCategoryIds Json?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  workspaceId        String
  workspace          Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdByUserId    String?
  createdBy          User?            @relation("DestinationCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  publishAttempts    PublishAttempt[]

  @@index([workspaceId, updatedAt])
}

model PublishAttempt {
  id              String      @id @default(cuid())
  pipelineRunId   String
  pipelineRun     PipelineRun @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)
  destinationId   String
  destination     Destination @relation(fields: [destinationId], references: [id])
  status          String      @default("pending")
  postStatus      String?
  progressMessage String?     @db.Text
  remotePostId    String?
  remoteUrl       String?
  error           String?
  createdAt       DateTime    @default(now())
}

model ResearchSource {
  id                     String                          @id @default(cuid())
  name                   String
  slug                   String
  category               String?
  sourceType             String                          @default("youtube")
  sourceUrl              String                          @map("youtubeUrl")
  externalId             String?                         @map("channelId")
  status                 String                          @default("active")
  defaultSummaryPromptId String?
  defaultSummaryPrompt   Prompt?                         @relation("ResearchSourceDefaultPrompt", fields: [defaultSummaryPromptId], references: [id], onDelete: SetNull)
  lastChecked            DateTime?
  createdAt              DateTime                        @default(now())
  updatedAt              DateTime                        @updatedAt
  workspaceId            String
  workspace              Workspace                       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  visibility             Visibility                      @default(PRIVATE)
  createdByUserId        String?
  createdBy              User?                           @relation("ResearchSourceCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  items                  ResearchItem[]
  scheduleSources        ScheduleSource[]
  scheduleTriggerSources SchedulePipelineTriggerSource[]
  subscriptions          WorkspaceFeedSubscription[]
  pipelineLinks          PipelineFeed[]
  pipelineLoops          PipelineLoop[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, visibility, updatedAt])
}

model WorkspaceFeedSubscription {
  workspaceId     String
  workspace       Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceId        String
  source          ResearchSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  createdByUserId String?
  createdBy       User?          @relation("FeedSubscriptionCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now())

  @@id([workspaceId, sourceId])
  @@index([sourceId])
}

model PipelineFeed {
  pipelineId String
  pipeline   Pipeline       @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  sourceId   String
  source     ResearchSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  alias      String?
  createdAt  DateTime       @default(now())

  @@id([pipelineId, sourceId])
  @@unique([pipelineId, alias])
  @@index([sourceId])
}

model Schedule {
  id              String                   @id @default(cuid())
  name            String                   @unique
  enabled         Boolean                  @default(false)
  cadenceType     String                   @default("manual")
  timezone        String                   @default("UTC")
  minuteOfHour    Int?
  timeOfDay       String?
  dayOfWeek       Int?
  dayOfMonth      Int?
  nextRunAt       DateTime?
  lastRunAt       DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  workspaceId     String
  workspace       Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdByUserId String?
  createdBy       User?                    @relation("ScheduleCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  sources         ScheduleSource[]
  pipelineActions SchedulePipelineAction[]
  executions      ScheduleExecution[]

  @@index([enabled, nextRunAt])
  @@index([workspaceId, updatedAt])
}

model ScheduleSource {
  id         String         @id @default(cuid())
  scheduleId String
  schedule   Schedule       @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  sourceId   String
  source     ResearchSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sortOrder  Int            @default(0)

  @@unique([scheduleId, sourceId])
}

model SchedulePipelineAction {
  id                String                          @id @default(cuid())
  scheduleId        String
  schedule          Schedule                        @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  pipelineId        String
  pipeline          Pipeline                        @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  triggerPolicy     String                          @default("always")
  variableOverrides Json?
  sortOrder         Int                             @default(0)
  createdAt         DateTime                        @default(now())
  updatedAt         DateTime                        @updatedAt
  triggerSources    SchedulePipelineTriggerSource[]
  executions        SchedulePipelineExecution[]

  @@unique([scheduleId, pipelineId])
}

model SchedulePipelineTriggerSource {
  id       String                 @id @default(cuid())
  actionId String
  action   SchedulePipelineAction @relation(fields: [actionId], references: [id], onDelete: Cascade)
  sourceId String
  source   ResearchSource         @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  cursorAt DateTime               @default(now())

  @@unique([actionId, sourceId])
}

model ScheduleExecution {
  id                 String                      @id @default(cuid())
  scheduleId         String
  schedule           Schedule                    @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  origin             String                      @default("manual")
  dedupeKey          String                      @unique
  status             String                      @default("queued")
  scheduledFor       DateTime?
  cutoffAt           DateTime?
  skipReason         String?
  error              String?                     @db.Text
  leaseExpiresAt     DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  createdAt          DateTime                    @default(now())
  researchChecks     ScheduleResearchCheck[]
  pipelineExecutions SchedulePipelineExecution[]

  @@index([status, leaseExpiresAt])
  @@index([scheduleId, createdAt])
}

model ScheduleResearchCheck {
  id           String            @id @default(cuid())
  executionId  String
  execution    ScheduleExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  sourceId     String?
  sourceName   String
  status       String            @default("pending")
  newCount     Int               @default(0)
  updatedCount Int               @default(0)
  error        String?           @db.Text
  startedAt    DateTime?
  completedAt  DateTime?

  @@unique([executionId, sourceId])
}

model SchedulePipelineExecution {
  id              String                  @id @default(cuid())
  executionId     String
  execution       ScheduleExecution       @relation(fields: [executionId], references: [id], onDelete: Cascade)
  actionId        String?
  action          SchedulePipelineAction? @relation(fields: [actionId], references: [id], onDelete: SetNull)
  pipelineId      String
  pipelineName    String
  status          String                  @default("pending")
  reason          String?
  eligibleItemIds Json?
  pinnedItemIds   Json?
  pipelineRun     PipelineRun?
  createdAt       DateTime                @default(now())
  completedAt     DateTime?

  @@unique([executionId, actionId])
  @@index([pipelineId])
}

model ResearchFetchCache {
  id        String   @id
  cacheKey  String   @db.Text
  payload   Json
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ResearchItem {
  id                 String            @id @default(cuid())
  sourceId           String
  source             ResearchSource    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  externalId         String            @map("videoId")
  title              String            @map("videoTitle")
  itemUrl            String            @map("videoUrl")
  publishedAt        DateTime
  content            String?           @map("transcript") @db.LongText
  contentStatus      String?
  contentErrorReason String?           @db.Text
  contentCheckedAt   DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  summaries          ResearchSummary[]

  @@unique([sourceId, externalId], map: "ResearchItem_sourceId_videoId_key")
}

model ResearchSummary {
  id        String       @id @default(cuid())
  itemId    String
  item      ResearchItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  promptId  String
  prompt    Prompt       @relation(fields: [promptId], references: [id], onDelete: Cascade)
  text      String?      @db.Text
  status    String       @default("pending")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([itemId, promptId])
}

model LibraryAgent {
  id           String   @id @default(cuid())
  uid          String
  name         String
  description  String?  @db.Text
  category     String   @default("general")
  tags         Json     @default("[]")
  systemPrompt String   @db.Text
  userPrompt   String   @db.Text
  outputTarget String   @default("body")
  outputFormat String   @default("text")
  promptHash   String   @unique
  usageCount   Int      @default(0)
  sourceRunId  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Agent {
  id                String          @id @default(cuid())
  workspaceId       String
  workspace         Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  visibility        Visibility      @default(PRIVATE)
  key               String
  slug              String
  name              String
  description       String?         @db.Text
  category          String          @default("general")
  tags              Json            @default("[]")
  kind              AgentKind       @default(AI_TEXT)
  defaultUid        String           @default("agent")
  systemPrompt      String           @db.Text
  userPrompt        String           @db.Text
  outputTarget      String           @default("body")
  outputFormat      String           @default("text")
  sourceAgentId     String?
  sourceAgent       Agent?           @relation("AgentForks", fields: [sourceAgentId], references: [id], onDelete: SetNull)
  forks             Agent[]          @relation("AgentForks")
  createdByUserId   String?
  createdBy         User?            @relation("AgentCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  usageCount        Int              @default(0)
  agentHash         String
  pipelineSnapshots PipelineAgent[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([workspaceId, key])
  @@unique([workspaceId, slug])
  @@unique([workspaceId, agentHash])
  @@index([workspaceId, visibility, updatedAt])
  @@index([sourceAgentId])
}

model Prompt {
  id                        String            @id @default(cuid())
  slug                      String
  key                       String?
  name                      String
  description               String?           @db.Text
  kind                      PromptKind        @default(TRANSFORMATIONAL)
  category                  String            @default("general")
  tags                      Json              @default("[]")
  systemPrompt              String            @db.Text
  userPrompt                String            @db.Text
  uid                       String?
  outputTarget              String?
  outputFormat              String?           @default("text")
  visibility                Visibility        @default(PRIVATE)
  workspaceId               String?
  workspace                 Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  promptHash                String
  usageCount                Int               @default(0)
  sortOrder                 Int               @default(0)
  isDefault                 Boolean           @default(false)
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt
  defaultForResearchSources ResearchSource[]  @relation("ResearchSourceDefaultPrompt")
  researchSummaries         ResearchSummary[]
  sourcePromptId            String?
  sourcePrompt              Prompt?           @relation("PromptForks", fields: [sourcePromptId], references: [id], onDelete: SetNull)
  forks                     Prompt[]           @relation("PromptForks")

  @@index([kind])
  @@index([category])
  @@unique([workspaceId, slug])
  @@unique([workspaceId, key])
  @@unique([workspaceId, promptHash])
  @@index([sourcePromptId])
}

model PipelineLoop {
  id             String          @id @default(cuid())
  pipelineId     String          @unique
  pipeline       Pipeline        @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  loopType       String          @default("research_feed")
  sourceId       String?
  source         ResearchSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  cursorMode     String          @default("all_stored")
  cursorAt       DateTime?
  dateRangeStart DateTime?
  dateRangeEnd   DateTime?
  variableMap    Json?
  datasetConfig  Json?
  maxBatchSize   Int             @default(50)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model PipelineRunBatch {
  id             String        @id @default(cuid())
  pipelineId     String
  pipeline       Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  label          String?
  loopType       String        @default("research_feed")
  sourceId       String?
  sourceName     String?
  cursorMode     String?
  dryRun         Boolean       @default(true)
  status         String        @default("queued")
  totalCount     Int           @default(0)
  completedCount Int           @default(0)
  failedCount    Int           @default(0)
  skippedCount   Int           @default(0)
  createdAt      DateTime      @default(now())
  completedAt    DateTime?
  runs           PipelineRun[]

  @@index([pipelineId, createdAt])
}

model Workflow {
  id               String         @id @default(cuid())
  workspaceId      String
  workspace        Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  visibility       Visibility     @default(PRIVATE)
  key              String
  slug             String
  name             String
  description      String?        @db.Text
  category         String         @default("general")
  tags             Json           @default("[]")
  sortOrder        Int            @default(0)
  sourceWorkflowId String?
  sourceWorkflow   Workflow?      @relation("WorkflowForks", fields: [sourceWorkflowId], references: [id], onDelete: SetNull)
  forks            Workflow[]     @relation("WorkflowForks")
  forkedAt         DateTime?
  sourceVersionAt  DateTime?
  createdByUserId  String?
  usageCount       Int            @default(0)
  nodes            WorkflowNode[]
  runs             PipelineRun[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([workspaceId, key])
  @@unique([workspaceId, slug])
  @@index([workspaceId, visibility, updatedAt])
  @@index([sourceWorkflowId])
}

model WorkflowNode {
  id                String          @id @default(cuid())
  workflowId        String
  workflow          Workflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  uid               String
  kind              AgentKind       @default(AI_TEXT)
  name              String
  description       String?         @db.Text
  systemPrompt      String          @db.Text
  userPrompt        String          @db.Text
  outputTarget      String          @default("none")
  outputFormat      String          @default("markdown")
  imageMode         String          @default("generate")
  enabled           Boolean         @default(true)
  sortOrder         Int             @default(0)
  pipelineSnapshots PipelineAgent[] @relation("PipelineAgentWorkflowNode")
  agentRuns         AgentRun[]      @relation("WorkflowNodeRuns")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([workflowId, uid])
  @@index([workflowId, sortOrder])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         String    @default("OWNER")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Account {
  id              String           @id @default(cuid())
  name            String
  slug            String           @unique
  category        String?
  phone           String?
  email           String?
  description     String?          @db.Text
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  pipelines       Pipeline[]
  destinations    Destination[]
  researchSources ResearchSource[]
}

model Pipeline {
  id           String             @id @default(cuid())
  accountId    String
  account      Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name         String
  slug         String
  description  String?
  category     String?
  status       String             @default("draft")
  destinationId String?
  researchSourceId String?
  researchSummaryPromptId String?
  bodyComposer Json?
  dryRun       Boolean            @default(true)
  scheduleMode String             @default("manual")
  frequency    String?
  timeOfDay    String?
  timezone     String?
  isPaused     Boolean            @default(false)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  variables    PipelineVariable[]
  agents       PipelineAgent[]
  runs         PipelineRun[]

  @@unique([accountId, slug])
}

model PipelineVariable {
  id           String   @id @default(cuid())
  pipelineId   String
  pipeline     Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  key          String
  label        String?
  type         String   @default("text")
  required     Boolean  @default(false)
  defaultValue String?
  exampleValue String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PipelineAgent {
  id           String   @id @default(cuid())
  pipelineId   String
  pipeline     Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  uid          String
  name         String
  systemPrompt String   @db.Text
  userPrompt   String   @db.Text
  outputTarget String
  outputFormat String   @default("text")
  enabled      Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([pipelineId, uid])
}

model PipelineRun {
  id              String           @id @default(cuid())
  accountId       String
  pipelineId      String
  pipeline        Pipeline         @relation(fields: [pipelineId], references: [id])
  status          String           @default("queued")
  dryRun          Boolean          @default(true)
  variables       Json
  generatedPost   Json?
  outputFolder    String?
  destinationId   String?
  startedAt       DateTime         @default(now())
  completedAt     DateTime?
  error           String?          @db.Text
  agentRuns       AgentRun[]
  assets          RunAsset[]
  publishAttempts PublishAttempt[]
}

model AgentRun {
  id                   String      @id @default(cuid())
  pipelineRunId        String
  pipelineRun          PipelineRun @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)
  agentUid             String
  agentName            String
  outputTarget         String
  renderedSystemPrompt String      @db.Text
  renderedUserPrompt   String      @db.Text
  inputHash            String?
  cacheStatus          String?
  reusedFromAgentRunId String?
  outputText           String?     @db.Text
  outputJson           Json?
  status               String      @default("queued")
  error                String?
  sortOrder            Int         @default(0)
  startedAt            DateTime?
  completedAt          DateTime?

  @@index([agentUid, inputHash])
}

model RunAsset {
  id            String      @id @default(cuid())
  pipelineRunId String
  pipelineRun   PipelineRun @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)
  type          String
  label         String
  filename      String
  path          String
  url           String?
  createdAt     DateTime    @default(now())
}

model Destination {
  id              String           @id @default(cuid())
  accountId       String
  account         Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type            String           @default("wordpress")
  name            String
  siteUrl         String
  authType        String           @default("application_password")
  username        String?
  encryptedSecret String
  defaultStatus   String           @default("draft")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  publishAttempts PublishAttempt[]
}

model PublishAttempt {
  id            String      @id @default(cuid())
  pipelineRunId String
  pipelineRun   PipelineRun @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)
  destinationId String
  destination   Destination @relation(fields: [destinationId], references: [id])
  status        String      @default("pending")
  remotePostId  String?
  remoteUrl     String?
  error         String?
  createdAt     DateTime    @default(now())
}

model ResearchSource {
  id          String         @id @default(cuid())
  accountId   String
  account     Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  category    String?
  sourceType  String         @default("youtube")
  sourceUrl   String         @map("youtubeUrl")
  externalId  String?        @map("channelId")
  status      String         @default("active")
  lastChecked DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  items       ResearchItem[]

  @@unique([accountId, slug])
}

model ResearchFetchCache {
  id        String   @id
  cacheKey  String   @db.Text
  payload   Json
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ResearchItem {
  id          String            @id @default(cuid())
  sourceId    String
  source      ResearchSource    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  externalId  String            @map("videoId")
  title       String            @map("videoTitle")
  itemUrl     String            @map("videoUrl")
  publishedAt DateTime
  content     String?           @db.LongText @map("transcript")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  summaries   ResearchSummary[]

  @@unique([sourceId, externalId], map: "ResearchItem_sourceId_videoId_key")
}

model SummaryPrompt {
  id           String            @id @default(cuid())
  name         String
  description  String?
  systemPrompt String            @db.Text
  userPrompt   String            @db.Text
  isDefault    Boolean           @default(false)
  sortOrder    Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  summaries    ResearchSummary[]
}

model ResearchSummary {
  id        String        @id @default(cuid())
  itemId    String
  item      ResearchItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  promptId  String
  prompt    SummaryPrompt @relation(fields: [promptId], references: [id], onDelete: Cascade)
  text      String?       @db.Text
  status    String        @default("pending")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([itemId, promptId])
}

model LibraryAgent {
  id           String   @id @default(cuid())
  uid          String
  name         String
  description  String?  @db.Text
  category     String   @default("general")
  tags         Json     @default("[]")
  systemPrompt String   @db.Text
  userPrompt   String   @db.Text
  outputTarget String   @default("body")
  outputFormat String   @default("text")
  promptHash   String   @unique
  usageCount   Int      @default(0)
  sourceRunId  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
